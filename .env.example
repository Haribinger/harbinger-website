# =============================================================================
# Harbinger Website — Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in values before starting.
#
#   cp .env.example .env
#
# This is a static showcase site — no database or auth required.
# =============================================================================

# TCP port the server listens on.
PORT=8080

# Set to "production" for optimized static serving.
NODE_ENV=production
